generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id           BigInt   @id @default(autoincrement())
  phone_number String   @unique @db.VarChar(20)
  language     String   @default("tr") @db.VarChar(5)
  plan_type    String   @default("free") @db.Text
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
  premium_until DateTime? @db.Timestamptz(6)

  magnets  magnets[]
  memories memories[]
}

model magnets {
  id                 BigInt    @id @default(autoincrement())
  magnet_code        String    @unique @db.VarChar(100)
  user_id            BigInt?
  is_active          Boolean   @default(false)
  first_activated_at DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)

  user      users?      @relation(fields: [user_id], references: [id], onDelete: SetNull)
  memory    memories?
  scan_logs scan_logs[]

  @@index([user_id])
}

model memories {
  id               BigInt    @id @default(autoincrement())
  user_id          BigInt
  magnet_id        BigInt    @unique
  title            String    @db.VarChar(255)
  title_tr         String?   @db.VarChar(255)
  title_en         String?   @db.VarChar(255)
  subtitle         String?   @db.VarChar(255)
  subtitle_tr      String?   @db.VarChar(255)
  subtitle_en      String?   @db.VarChar(255)
  location_text    String?   @db.VarChar(255)
  location_text_tr String?   @db.VarChar(255)
  location_text_en String?   @db.VarChar(255)
  memory_date      DateTime? @db.Date
  cover_image_path String?
  cover_position   String? @default("center") @db.Text
  cover_position_percent Int? @default(50)
  status           String    @default("draft") @db.VarChar(20)
  selected_lang    String?   @default("tr") @db.VarChar(5)
  edit_password_hash String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  user         users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  magnet       magnets        @relation(fields: [magnet_id], references: [id], onDelete: Cascade)
  memory_items memory_items[]

  @@index([user_id])
}

model memory_items {
  id              BigInt   @id @default(autoincrement())
  memory_id       BigInt
  item_type       String   @db.VarChar(20)
  title           String?  @db.VarChar(255)
  title_tr        String?  @db.VarChar(255)
  title_en        String?  @db.VarChar(255)
  content_text    String?
  content_text_tr String?
  content_text_en String?
  file_path       String?
  thumbnail_path  String?
  sort_order      Int      @default(0)
  is_visible      Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  memory memories @relation(fields: [memory_id], references: [id], onDelete: Cascade)

  @@index([memory_id, sort_order])
}

model otp_codes {
  id           BigInt   @id @default(autoincrement())
  phone_number String   @db.VarChar(20)
  code         String   @db.VarChar(10)
  expires_at   DateTime @db.Timestamptz(6)
  is_used      Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([phone_number])
}

model scan_logs {
  id          BigInt   @id @default(autoincrement())
  magnet_id   BigInt
  scanned_at  DateTime @default(now()) @db.Timestamptz(6)
  device_info String?
  ip_address  String?  @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  magnet magnets @relation(fields: [magnet_id], references: [id], onDelete: Cascade)

  @@index([magnet_id])
}